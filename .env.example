# Torii CLI Configuration
# Copy this to .env and fill in your values

# Required: Your Torii API key (get it from https://app.toriihq.com/team/settings/apiAccess)
TORII_API_KEY=

# Optional: Override the base URL (default: https://api.toriihq.com/v1.0)
# TORII_BASE_URL=https://api.toriihq.com/v1.0

# Optional: Access mode — "read-only" (default) or "full"
# WARNING: "full" mode allows write operations against your production Torii environment.
# Only enable this when you explicitly need to create, update, or delete resources.
# TORII_MODE=read-only
